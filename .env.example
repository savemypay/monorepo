# Application
APPLICATION_HOST=0.0.0.0
APPLICATION_PORT=8001
ROOT_PATH=/smp
SMS_PROVIDER=sns
EMAIL_PROVIDER=ses
AWS_REGION=us-west-2
SMSCOUNTRY_API_KEY=your_smscountry_api_key
SMSCOUNTRY_SENDER=your_sender_id

# JWT auth
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
GAME_ACCESS_TOKEN_EXPIRE_DAYS=3650
GAME_LEADERBOARD_CACHE_TTL_SECONDS=10

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/app_db

# CORS / hosts
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# Runtime
ENVIRONMENT=development
LOG_LEVEL=info
